# Server
PORT=8081
DB_PATH=./data/poster.db

# OpenAI (required)
OPENAI_API_KEY=sk-your-openai-key-here

# NewsAPI (free at newsapi.org — optional but recommended)
NEWS_API_KEY=your-newsapi-key-here

# LinkedIn OAuth (for actual posting)
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your-access-token
LINKEDIN_PERSON_ID=your-person-id

# Your name for AI post generation
AUTHOR_NAME=Dheeraj Reddy
